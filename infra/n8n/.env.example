# Local n8n settings for Editorial AI.
# Copy to .env or run scripts/n8n.ps1 start to generate a local .env.

N8N_IMAGE=docker.n8n.io/n8nio/n8n:latest
N8N_BIND_ADDRESS=127.0.0.1
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
TZ=Europe/Madrid
GENERIC_TIMEZONE=Europe/Madrid
N8N_SECURE_COOKIE=false

# Keep this value stable. Changing it makes existing n8n credentials unreadable.
N8N_ENCRYPTION_KEY=replace-with-a-generated-secret
